@model List<DemoChatRealTime.Models.DTOs.ChatRoomDto>
@{
    ViewData["Title"] = "Chat";
    Layout = null;

    var userId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var displayName = User.FindFirst("DisplayName")?.Value ?? User.Identity?.Name;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Chat App</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        :root {
            --sidebar-width: 300px;
            --primary-color: #667eea;
            --primary-dark: #5a67d8;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            overflow: hidden;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: #f0f2f5;
        }

        .chat-container { display: flex; height: 100vh; }

        .sidebar {
            width: var(--sidebar-width);
            background: #fff;
            border-right: 1px solid #e0e0e0;
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
        }

        .sidebar-header {
            padding: 12px 16px;
            background: var(--primary-color);
            color: #fff;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 6px;
        }

        .sidebar-header h5 { margin: 0; font-size: 18px; }
        .sidebar-header .btn-group-actions { display: flex; gap: 4px; }

        .sidebar-header .btn-icon {
            background: rgba(255,255,255,0.2);
            border: none;
            color: #fff;
            border-radius: 8px;
            width: 34px;
            height: 34px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 16px;
            transition: background 0.15s;
        }

        .sidebar-header .btn-icon:hover { background: rgba(255,255,255,0.35); }

        .user-info {
            padding: 10px 16px;
            background: #f8f9fa;
            border-bottom: 1px solid #e0e0e0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .user-info .user-name { font-weight: 600; color: #333; font-size: 14px; }

        .room-list { flex: 1; overflow-y: auto; list-style: none; padding: 0; margin: 0; }

        .room-item {
            padding: 12px 16px;
            border-bottom: 1px solid #f0f0f0;
            cursor: pointer;
            transition: background 0.15s;
            position: relative;
        }

        .room-item:hover { background: #f5f6f8; }
        .room-item.active { background: #e8eaf6; border-left: 3px solid var(--primary-color); }
        .room-item .room-name { font-weight: 600; color: #333; margin-bottom: 2px; font-size: 14px; }

        .room-item .room-preview {
            font-size: 12px;
            color: #888;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 200px;
        }

        .room-item .room-meta { font-size: 11px; color: #aaa; }

        .room-item .unread-badge {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            background: #f44336;
            color: #fff;
            font-size: 11px;
            font-weight: 700;
            border-radius: 10px;
            min-width: 20px;
            height: 20px;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 0 6px;
        }

        .room-item .unread-badge.show { display: flex; }

        .online-section {
            border-top: 1px solid #e0e0e0;
            max-height: 180px;
            overflow-y: auto;
        }

        .online-section h6 {
            padding: 8px 16px 4px;
            margin: 0;
            font-size: 11px;
            text-transform: uppercase;
            color: #888;
            letter-spacing: 0.5px;
        }

        .online-user {
            padding: 5px 16px;
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .online-dot {
            width: 8px; height: 8px;
            border-radius: 50%;
            background: #4caf50;
            display: inline-block;
            flex-shrink: 0;
        }

        .chat-main { flex: 1; display: flex; flex-direction: column; min-width: 0; }

        .chat-header {
            padding: 12px 20px;
            background: #fff;
            border-bottom: 1px solid #e0e0e0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .chat-header h5 { margin: 0; color: #333; font-size: 16px; }
        .chat-header .room-members { font-size: 12px; color: #888; }

        .messages-container {
            flex: 1;
            overflow-y: auto;
            padding: 16px 20px;
            display: flex;
            flex-direction: column;
            gap: 3px;
            background: #f0f2f5;
            /* FIX: Đảm bảo messages container co lại thay vì tràn */
            min-height: 0;
        }

        .message {
            display: flex;
            flex-direction: column;
            max-width: 70%;
            animation: fadeIn 0.2s ease;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .message.mine { align-self: flex-end; }
        .message.others { align-self: flex-start; }

        .message .sender-name {
            font-size: 11px; color: #888;
            margin-bottom: 1px; padding: 0 12px;
        }

        .message .bubble {
            padding: 8px 14px;
            border-radius: 18px;
            font-size: 14px;
            line-height: 1.45;
            word-wrap: break-word;
        }

        .message.mine .bubble {
            background: var(--primary-color);
            color: #fff;
            border-bottom-right-radius: 4px;
        }

        .message.others .bubble {
            background: #fff;
            color: #333;
            border-bottom-left-radius: 4px;
            box-shadow: 0 1px 2px rgba(0,0,0,0.06);
        }

        .message .time {
            font-size: 10px; color: #aaa;
            padding: 1px 12px 0;
        }

        .message.mine .time { text-align: right; }

        .system-message {
            text-align: center; font-size: 12px;
            color: #888; padding: 6px;
        }

        .typing-indicator {
            font-size: 12px; color: #888;
            padding: 0 20px 4px; min-height: 20px;
            font-style: italic;
        }

        .chat-input-area {
            padding: 10px 20px;
            background: #fff;
            border-top: 1px solid #e0e0e0;
        }

        .chat-input-group { display: flex; gap: 8px; align-items: center; }

        .chat-input-group input {
            flex: 1;
            border: 1px solid #ddd;
            border-radius: 24px;
            padding: 10px 18px;
            font-size: 14px;
            outline: none;
            transition: border-color 0.2s;
        }

        .chat-input-group input:focus { border-color: var(--primary-color); }

        .btn-send {
            background: var(--primary-color);
            color: #fff; border: none;
            border-radius: 50%;
            width: 40px; height: 40px;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; transition: background 0.2s; font-size: 18px;
        }

        .btn-send:hover { background: var(--primary-dark); }
        .btn-send:disabled { background: #ccc; cursor: not-allowed; }

        .empty-state {
            flex: 1; display: flex;
            align-items: center; justify-content: center;
            flex-direction: column; color: #aaa;
            background: #f0f2f5;
        }

        .empty-state .icon { font-size: 64px; margin-bottom: 12px; }

        /* NOTE: Ẩn chatContent bằng CSS thay vì d-none để tránh !important conflict */
        .chat-content-hidden { display: none !important; }
        .chat-content-visible {
            display: flex !important;
            flex: 1;
            flex-direction: column;
            /* FIX: Giới hạn chiều cao để messages không đẩy input ra ngoài viewport */
            min-height: 0;
            overflow: hidden;
        }

        .messages-container {
            flex: 1;
            overflow-y: auto;
            padding: 16px 20px;
            display: flex;
            flex-direction: column;
            gap: 3px;
            background: #f0f2f5;
            /* FIX: Đảm bảo messages container co lại thay vì tràn */
            min-height: 0;
        }

        /* Connection status */
        .connection-status {
            padding: 3px 16px; font-size: 11px;
            text-align: center; transition: all 0.3s;
        }

        .connection-status.connected { background: #e8f5e9; color: #4caf50; }
        .connection-status.disconnected { background: #ffebee; color: #f44336; }
        .connection-status.reconnecting { background: #fff3e0; color: #ff9800; }

        /* Toast notification */
        .toast-container {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 9999;
        }

        .chat-toast {
            background: #333;
            color: #fff;
            padding: 10px 16px;
            border-radius: 10px;
            margin-top: 6px;
            font-size: 13px;
            box-shadow: 0 4px 16px rgba(0,0,0,0.25);
            animation: slideIn 0.3s ease;
            max-width: 320px;
        }

        .chat-toast .toast-room { font-weight: 700; color: #90caf9; }
        .chat-toast .toast-msg { opacity: 0.9; }

        @@keyframes slideIn {
            from { opacity: 0; transform: translateX(30px); }
            to { opacity: 1; transform: translateX(0); }
        }

        /* Browse rooms list in modal */
        .browse-room-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid #f0f0f0;
        }

        .browse-room-item:last-child { border-bottom: none; }
        .browse-room-item .room-info { flex: 1; }
        .browse-room-item .room-info strong { font-size: 14px; }
        .browse-room-item .room-info small { color: #888; }

        /* Responsive */
        @@media (max-width: 768px) {
            .sidebar { width: 100%; position: absolute; z-index: 10; }
            .chat-main { width: 100%; }
        }
    </style>
</head>
<body>
    <div class="chat-container">
        <!-- ===== SIDEBAR ===== -->
        <div class="sidebar">
            <div class="sidebar-header">
                <h5>Chat</h5>
                <div class="btn-group-actions">
                    <button class="btn-icon" data-bs-toggle="modal" data-bs-target="#browseRoomsModal" title="Tìm phòng chat">🔍</button>
                    <button class="btn-icon" data-bs-toggle="modal" data-bs-target="#createRoomModal" title="Tạo phòng mới">➕</button>
                </div>
            </div>

            <div class="user-info">
                <div>
                    <span class="online-dot"></span>
                    <span class="user-name">@displayName</span>
                </div>
                <form asp-controller="Auth" asp-action="Logout" method="post" style="display:inline;">
                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Đăng xuất" style="font-size:13px;padding:2px 8px;">🚪</button>
                </form>
            </div>

            <div id="connectionStatus" class="connection-status disconnected">
                Đang kết nối...
            </div>

            <ul class="room-list" id="roomList">
                @foreach (var room in Model)
                {
                    <li class="room-item" data-room-id="@room.Id" onclick="selectRoom(@room.Id, '@Html.Raw(room.Name.Replace("'", "\\'"))')">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="room-name">@room.Name</span>
                            <span class="room-meta">@room.MemberCount 👤</span>
                        </div>
                        <div class="room-preview">
                            @(room.LastMessage ?? "Chưa có tin nhắn")
                        </div>
                        <span class="unread-badge" id="unread-@room.Id">0</span>
                    </li>
                }
            </ul>

            <div class="online-section">
                <h6>🟢 Online (<span id="onlineCount">0</span>)</h6>
                <div id="onlineUsersList"></div>
            </div>
        </div>

        <!-- ===== MAIN CHAT AREA ===== -->
        <div class="chat-main">
            <div class="empty-state" id="emptyState">
                <div class="icon">💬</div>
                <h5>Chọn một phòng chat để bắt đầu</h5>
                <p class="text-muted">Hoặc tạo phòng mới ➕ / Tìm phòng 🔍</p>
            </div>

            <!-- NOTE: Dùng class riêng thay d-none để tránh Bootstrap !important conflict -->
            <div id="chatContent" class="chat-content-hidden">
                <div class="chat-header">
                    <div>
                        <h5 id="currentRoomName">--</h5>
                        <span class="room-members" id="currentRoomMembers"></span>
                    </div>
                </div>

                <div class="messages-container" id="messagesContainer"></div>

                <div class="typing-indicator" id="typingIndicator"></div>

                <div class="chat-input-area">
                    <div class="chat-input-group">
                        <input type="text" id="messageInput"
                               placeholder="Nhập tin nhắn..." autocomplete="off" maxlength="2000" />
                        <button class="btn-send" id="sendBtn" onclick="sendMessage()" disabled title="Gửi">➤</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="toast-container" id="toastContainer"></div>

    <!-- ===== CREATE ROOM MODAL ===== -->
    <div class="modal fade" id="createRoomModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title">➕ Tạo phòng chat mới</h6>
                    <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="text" id="newRoomName" class="form-control" placeholder="Nhập tên phòng..." maxlength="200"
                           onkeydown="if(event.key==='Enter'){createRoom();}" />
                </div>
                <div class="modal-footer py-2">
                    <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-sm btn-primary" onclick="createRoom()">Tạo</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== BROWSE ROOMS MODAL ===== -->
    <div class="modal fade" id="browseRoomsModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title">🔍 Tìm phòng chat</h6>
                    <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" style="max-height:400px; overflow-y:auto;">
                    <div id="browseRoomsList">
                        <p class="text-muted text-center">Đang tải...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== SCRIPTS ===== -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <script>
        // ===== STATE =====
        const currentUserId = @userId;
        const currentDisplayName = "@Html.Raw(displayName?.Replace("\"", "\\\"").Replace("'", "\\'"))";

        let currentRoomId = null;
        let connection = null;
        let typingTimeout = null;
        let isTyping = false;
        let oldestMessageId = 0;
        const unreadCounts = {};
        const roomNameMap = {};

        @foreach (var room in Model)
        {
            @:roomNameMap[@room.Id] = "@Html.Raw(room.Name.Replace("\"", "\\\""))";
        }

        // ===== SIGNALR CONNECTION =====
        connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .withAutomaticReconnect([0, 2000, 5000, 10000, 30000])
            .configureLogging(signalR.LogLevel.Warning)
            .build();

        connection.on("ReceiveMessage", function (msg) {
            if (msg.chatRoomId === currentRoomId) {
                if (document.querySelector(`[data-message-id="${msg.id}"]`)) return;
                appendMessage(msg);
                scrollToBottom();
            } else {
                incrementUnread(msg.chatRoomId);
                showToast(msg.chatRoomId, msg.senderName, msg.content);
            }
            updateRoomPreview(msg.chatRoomId, msg.content);
        });

        connection.on("UserOnline", function (user) { addOnlineUser(user); });
        connection.on("UserOffline", function (user) { removeOnlineUser(user.userId); });

        connection.on("UserTyping", function (data) {
            if (data.roomId === currentRoomId) showTypingIndicator(data.displayName);
        });

        connection.on("UserStoppedTyping", function (data) {
            if (data.roomId === currentRoomId) hideTypingIndicator();
        });

        connection.on("UserJoinedRoom", function (data) {
            if (data.roomId === currentRoomId) {
                appendSystemMessage(`${data.displayName} đã tham gia phòng`);
            }
        });

        connection.on("MessageError", function (error) { showToast(0, "Lỗi", error); });

        connection.on("JoinedRoom", function (roomId) { refreshRoomList(); });

        connection.onreconnecting(() => updateConnectionStatus("reconnecting", "⟳ Đang kết nối lại..."));
        connection.onreconnected(() => updateConnectionStatus("connected", "✓ Đã kết nối"));
        connection.onclose(() => {
            updateConnectionStatus("disconnected", "✗ Mất kết nối");
            setTimeout(startConnection, 5000);
        });

        async function startConnection() {
            try {
                await connection.start();
                updateConnectionStatus("connected", "✓ Đã kết nối");
                document.getElementById("sendBtn").disabled = false;
            } catch (err) {
                updateConnectionStatus("disconnected", "✗ Lỗi kết nối");
                console.error("SignalR error:", err);
                setTimeout(startConnection, 5000);                                      
            }
        }

        startConnection();

        // ===== ROOM MANAGEMENT =====
        function selectRoom(roomId, roomName) {
            try {
                currentRoomId = roomId;
                oldestMessageId = 0;

                // Reset unread
                unreadCounts[roomId] = 0;
                updateUnreadBadge(roomId);

                // NOTE: Dùng class riêng thay vì d-none để đảm bảo hiển thị đúng
                document.getElementById("emptyState").style.display = "none";
                const chatContent = document.getElementById("chatContent");
                chatContent.className = "chat-content-visible";

                document.getElementById("currentRoomName").textContent = roomName;
                document.getElementById("messagesContainer").innerHTML = "";
                hideTypingIndicator();

                // Highlight active room
                document.querySelectorAll(".room-item").forEach(item => {
                    item.classList.toggle("active", parseInt(item.dataset.roomId) === roomId);
                });

                loadMessages(roomId);
                document.getElementById("messageInput").focus();
            } catch (err) {
                console.error("selectRoom error:", err);
            }
        }

        async function loadMessages(roomId, beforeId = 0) {
            try {
                const res = await fetch(`/Chat/GetMessages?roomId=${roomId}&beforeId=${beforeId}&pageSize=50`);
                if (!res.ok) return;
                const messages = await res.json();

                // Kiểm tra user đã chuyển room khác chưa
                if (roomId !== currentRoomId) return;

                const container = document.getElementById("messagesContainer");

                if (beforeId === 0) {
                    container.innerHTML = "";
                }

                container.querySelector(".load-more-btn")?.remove();

                if (messages.length >= 50) {
                    const btn = document.createElement("button");
                    btn.className = "load-more-btn";
                    btn.textContent = "🔄 Tải thêm tin nhắn cũ";
                    btn.onclick = () => loadMessages(roomId, oldestMessageId);
                    container.prepend(btn);
                }

                messages.forEach(msg => appendMessage(msg, beforeId > 0));

                if (messages.length > 0) {
                    oldestMessageId = messages[0].id;
                }

                if (beforeId === 0) scrollToBottom(true);
            } catch (err) {
                console.error("Load messages error:", err);
            }
        }

        // ===== SEND MESSAGE =====
        async function sendMessage() {
            const input = document.getElementById("messageInput");
            const content = input.value.trim();
            if (!content || !currentRoomId) return;

            input.value = "";
            input.focus();
            stopTypingNotify();

            try {
                await connection.invoke("SendMessage", {
                    content: content,
                    chatRoomId: currentRoomId
                });
            } catch (err) {
                console.error("Send error:", err);
                input.value = content;
                showToast(0, "Lỗi", "Không thể gửi tin nhắn. Kiểm tra kết nối.");
            }
        }

        document.getElementById("messageInput").addEventListener("keydown", function (e) {
            if (e.key === "Enter" && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });

        // ===== TYPING INDICATOR =====
        document.getElementById("messageInput").addEventListener("input", function () {
            if (!currentRoomId) return;
            if (!isTyping) {
                isTyping = true;
                connection.invoke("StartTyping", currentRoomId).catch(() => {});
            }
            clearTimeout(typingTimeout);
            typingTimeout = setTimeout(stopTypingNotify, 2000);
        });

        function stopTypingNotify() {
            if (isTyping && currentRoomId) {
                isTyping = false;
                connection.invoke("StopTyping", currentRoomId).catch(() => {});
            }
            clearTimeout(typingTimeout);
        }

        // ===== CREATE ROOM =====
        async function createRoom() {
            const nameInput = document.getElementById("newRoomName");
            const name = nameInput.value.trim();
            if (!name) return;

            try {
                const res = await fetch("/Chat/CreateRoom", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ name })
                });

                if (res.ok) {
                    const room = await res.json();
                    nameInput.value = "";
                    bootstrap.Modal.getInstance(document.getElementById("createRoomModal")).hide();
                    roomNameMap[room.id] = room.name;
                    addRoomToSidebar(room);
                    await connection.invoke("JoinRoom", room.id);
                    selectRoom(room.id, room.name);
                } else {
                    showToast(0, "Lỗi", "Không thể tạo phòng");
                }
            } catch (err) {
                console.error("Create room error:", err);
            }
        }

        // ===== BROWSE & JOIN ROOMS =====
        document.getElementById("browseRoomsModal").addEventListener("show.bs.modal", loadAvailableRooms);

        async function loadAvailableRooms() {
            const container = document.getElementById("browseRoomsList");
            container.innerHTML = '<p class="text-muted text-center">Đang tải...</p>';

            try {
                const res = await fetch("/Chat/GetAvailableRooms");
                const rooms = await res.json();

                if (rooms.length === 0) {
                    container.innerHTML = '<p class="text-muted text-center py-3">Bạn đã tham gia tất cả phòng!</p>';
                    return;
                }

                container.innerHTML = "";
                rooms.forEach(room => {
                    const div = document.createElement("div");
                    div.className = "browse-room-item";
                    div.innerHTML = `
                        <div class="room-info">
                            <strong>${escapeHtml(room.name)}</strong><br/>
                            <small>${room.memberCount} thành viên</small>
                        </div>
                        <button class="btn btn-sm btn-outline-primary" onclick="joinRoom(${room.id}, '${escapeHtml(room.name).replace(/'/g, "\\'")}')">
                            Tham gia
                        </button>
                    `;
                    container.appendChild(div);
                });
            } catch (err) {
                container.innerHTML = '<p class="text-danger text-center">Lỗi tải danh sách phòng</p>';
            }
        }

        async function joinRoom(roomId, roomName) {
            try {
                await connection.invoke("JoinRoom", roomId);
                roomNameMap[roomId] = roomName;
                bootstrap.Modal.getInstance(document.getElementById("browseRoomsModal")).hide();
                await refreshRoomList();
                selectRoom(roomId, roomName);
            } catch (err) {
                console.error("Join room error:", err);
            }
        }

        // ===== DOM HELPERS =====
        function appendMessage(message, prepend = false) {
            const container = document.getElementById("messagesContainer");

            if (document.querySelector(`[data-message-id="${message.id}"]`)) return;

            const isMine = message.senderId === currentUserId;
            const div = document.createElement("div");
            div.className = `message ${isMine ? 'mine' : 'others'}`;
            div.dataset.messageId = message.id;

            const time = new Date(message.sentAt).toLocaleTimeString("vi-VN", {
                hour: "2-digit", minute: "2-digit"
            });

            div.innerHTML = `
                ${!isMine ? `<span class="sender-name">${escapeHtml(message.senderName)}</span>` : ''}
                <div class="bubble">${escapeHtml(message.content)}</div>
                <span class="time">${time}</span>
            `;

            if (prepend) {
                const loadMoreBtn = container.querySelector(".load-more-btn");
                if (loadMoreBtn) loadMoreBtn.after(div);
                else container.prepend(div);
            } else {
                container.appendChild(div);
            }
        }

        function appendSystemMessage(text) {
            const container = document.getElementById("messagesContainer");
            const div = document.createElement("div");
            div.className = "system-message";
            div.textContent = `— ${text} —`;
            container.appendChild(div);
            scrollToBottom();
        }

        function scrollToBottom(force = false) {
            const c = document.getElementById("messagesContainer");
            const isNearBottom = c.scrollHeight - c.scrollTop - c.clientHeight < 150;
            if (force || isNearBottom) {
                requestAnimationFrame(() => { c.scrollTop = c.scrollHeight; });
            }
        }

        function showTypingIndicator(name) {
            const el = document.getElementById("typingIndicator");
            el.textContent = `${name} đang gõ...`;
            setTimeout(() => { if (el.textContent.includes(name)) el.textContent = ""; }, 3000);
        }

        function hideTypingIndicator() {
            document.getElementById("typingIndicator").textContent = "";
        }

        function updateConnectionStatus(status, text) {
            const el = document.getElementById("connectionStatus");
            el.className = `connection-status ${status}`;
            el.textContent = text;
            if (status === "connected") {
                setTimeout(() => { el.style.display = "none"; }, 2000);
            } else {
                el.style.display = "block";
            }
        }

        function updateRoomPreview(roomId, message) {
            const item = document.querySelector(`.room-item[data-room-id="${roomId}"]`);
            if (item) {
                const preview = item.querySelector(".room-preview");
                if (preview) preview.textContent = message;
            }
        }

        // ===== UNREAD COUNT =====
        function incrementUnread(roomId) {
            unreadCounts[roomId] = (unreadCounts[roomId] || 0) + 1;
            updateUnreadBadge(roomId);
        }

        function updateUnreadBadge(roomId) {
            const badge = document.getElementById(`unread-${roomId}`);
            if (!badge) return;
            const count = unreadCounts[roomId] || 0;
            badge.textContent = count > 99 ? "99+" : count;
            badge.classList.toggle("show", count > 0);
        }

        // ===== TOAST NOTIFICATIONS =====
        function showToast(roomId, sender, content) {
            const container = document.getElementById("toastContainer");
            const roomName = roomNameMap[roomId] || "Chat";
            const toast = document.createElement("div");
            toast.className = "chat-toast";
            toast.innerHTML = `
                <span class="toast-room">${escapeHtml(roomName)}</span>
                <br/><strong>${escapeHtml(sender)}</strong>: <span class="toast-msg">${escapeHtml(content.substring(0, 80))}${content.length > 80 ? '...' : ''}</span>
            `;

            if (roomId > 0) {
                toast.style.cursor = "pointer";
                toast.onclick = () => {
                    selectRoom(roomId, roomName);
                    toast.remove();
                };
            }

            container.appendChild(toast);
            setTimeout(() => toast.remove(), 4000);
        }

        // ===== SIDEBAR MANAGEMENT =====
        function addRoomToSidebar(room) {
            const list = document.getElementById("roomList");
            const li = document.createElement("li");
            li.className = "room-item";
            li.dataset.roomId = room.id;
            li.onclick = () => selectRoom(room.id, room.name);
            li.innerHTML = `
                <div class="d-flex justify-content-between align-items-center">
                    <span class="room-name">${escapeHtml(room.name)}</span>
                    <span class="room-meta">${room.memberCount} 👤</span>
                </div>
                <div class="room-preview">Chưa có tin nhắn</div>
                <span class="unread-badge" id="unread-${room.id}">0</span>
            `;
            list.prepend(li);
        }

        function addOnlineUser(user) {
            removeOnlineUser(user.userId);
            const list = document.getElementById("onlineUsersList");
            const div = document.createElement("div");
            div.className = "online-user";
            div.id = `online-${user.userId}`;
            div.innerHTML = `<span class="online-dot"></span> ${escapeHtml(user.displayName)}`;
            list.appendChild(div);
            updateOnlineCount();
        }

        function removeOnlineUser(userId) {
            document.getElementById(`online-${userId}`)?.remove();
            updateOnlineCount();
        }

        function updateOnlineCount() {
            document.getElementById("onlineCount").textContent =
                document.querySelectorAll("#onlineUsersList .online-user").length;
        }

        async function refreshRoomList() {
            try {
                const res = await fetch("/Chat/GetMyRooms");
                const rooms = await res.json();
                const list = document.getElementById("roomList");
                list.innerHTML = "";

                rooms.forEach(room => {
                    roomNameMap[room.id] = room.name;
                    const li = document.createElement("li");
                    li.className = `room-item ${room.id === currentRoomId ? 'active' : ''}`;
                    li.dataset.roomId = room.id;
                    li.onclick = () => selectRoom(room.id, room.name);
                    li.innerHTML = `
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="room-name">${escapeHtml(room.name)}</span>
                            <span class="room-meta">${room.memberCount} 👤</span>
                        </div>
                        <div class="room-preview">${escapeHtml(room.lastMessage || 'Chưa có tin nhắn')}</div>
                        <span class="unread-badge ${(unreadCounts[room.id] || 0) > 0 ? 'show' : ''}" id="unread-${room.id}">
                            ${unreadCounts[room.id] || 0}
                        </span>
                    `;
                    list.appendChild(li);
                });
            } catch (err) {
                console.error("Refresh rooms error:", err);
            }
        }

        function escapeHtml(text) {
            if (!text) return '';
            const d = document.createElement("div");
            d.textContent = text;
            return d.innerHTML;
        }
    </script>
</body>
</html>
